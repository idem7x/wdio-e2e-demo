# ===== Web (Saucedemo demo site) =====
HOST_WEB=https://www.saucedemo.com
WEB_USERNAME=standard_user
WEB_PASSWORD=secret_sauce

# ===== Android (Appium / public sample APK) =====
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
ANDROID_APK_DIR=./test/resources/apk
ANDROID_APK=ApiDemos-debug.apk
ANDROID_APP_PACKAGE=io.appium.android.apis
ANDROID_APP_ACTIVITY=.ApiDemos

# ===== Framework =====
RETRY=1
TIMEOUT=15000
REPORTS_FOLDER=
ALLURE_URL=http://localhost:8080

# ===== Optional: email report (uses Gmail SMTP) =====
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_MAIL_FROM=
EMAIL_MAIL_TO=
