{
  "name": "wdio-e2e-demo",
  "version": "1.0.0",
  "description": "Cross-platform E2E testing framework demo — WebdriverIO + Appium + Allure. Web, native Android, and mixed multi-browser orchestration.",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf allure-report report",
    "test:web": "npm run clean && npx wdio run test/config/wdio.web.ts",
    "test:android": "npx wdio run test/config/wdio.android.ts",
    "test:mix": "npx wdio run test/config/wdio.mix.ts",
    "allure:open": "allure open allure-report",
    "lint": "eslint . --fix && prettier --check \"test/**/*.ts\" --write"
  },
  "keywords": [
    "webdriverio",
    "appium",
    "typescript",
    "page-object-model",
    "e2e-testing",
    "allure"
  ],
  "author": "Maksym Zaselian",
  "license": "MIT",
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/fs-extra": "11.0.4",
    "@types/node": "22.18.12",
    "@types/nodemailer": "6.4.21",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "@wdio/allure-reporter": "9.20.0",
    "@wdio/appium-service": "9.20.0",
    "@wdio/cli": "9.22.0",
    "@wdio/local-runner": "9.20.0",
    "@wdio/mocha-framework": "9.20.0",
    "@wdio/spec-reporter": "9.20.0",
    "@wdio/types": "9.20.0",
    "allure-commandline": "2.34.1",
    "appium": "3.1.0",
    "appium-uiautomator2-driver": "6.0.0",
    "chai": "6.2.2",
    "dotenv": "16.4.1",
    "eslint": "8.40.0",
    "eslint-config-prettier": "10.1.2",
    "eslint-plugin-prettier": "5.2.6",
    "fs-extra": "11.3.2",
    "nodemailer": "7.0.11",
    "prettier": "3.5.3",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "wdio-video-reporter": "6.2.0",
    "winston": "3.17.0"
  }
}
